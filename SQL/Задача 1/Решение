Логика запроса: Сначала отбираем кейсы за нужный период и подтягиваем сумму долга. Затем отдельно считаем факты контакта (через DISTINCT кейсов в окне 7 дней) и платежи (сумму по кейсу за те же 7 дней). 
В финале агрегируем по стратегии, считая количества кейсов, суммы сборов и производные метрики.

Запрос:

-- Отбираем кейсы за период с 2026-02-01 по 2026-02-28
WITH actual_cases AS (
    SELECT сc.case_id,
           сc.account_id,
           сc.strategy_name,
           сc.start_date,
           aс.principal_amount
    FROM collection_cases AS cс
    INNER JOIN accounts AS aс ON cс.account_id = aс.account_id
    WHERE cс.start_date BETWEEN DATE '2026-02-01' AND DATE '2026-02-28'
),

-- Считаем все контакты за первые 7 дней
contact_events_7d AS (
    SELECT DISTINCT ac.case_id
    FROM actual_cases AS ac
    INNER JOIN contact_events AS ce 
        ON ce.case_id = ac.case_id
       AND ce.event_dttm >= ac.start_date
       AND ce.event_dttm < ac.start_date + INTERVAL '7 days'
),

-- Считаем сумму платежей за первые 7 дней
payments_7d AS (
    SELECT ac.case_id,
           SUM(p.payment_amount) AS collected_amount
    FROM actual_cases AS ac
    INNER JOIN payments AS p 
        ON p.account_id = ac.account_id
       AND p.payment_amount > 0
       AND p.payment_dttm >= c.start_date
       AND p.payment_dttm < c.start_date + INTERVAL '7 days'
    GROUP BY ac.case_id
)

-- Собираем все необходимые столбцы в одну таблицу
SELECT 
    ac.strategy_name,
    COUNT(*) AS total_cases,
    COUNT(ct.case_id) AS contacted_cases_7d,
    COUNT(p.case_id) AS paid_cases_7d,
    COALESCE(SUM(p.collected_amount), 0) AS collected_amount_7d,
    CASE 
        WHEN COUNT(p.case_id) > 0 
        THEN SUM(p.collected_amount) / COUNT(p.case_id)
        ELSE 0
    END AS avg_collected_per_paid_case_7d,
    CASE 
        WHEN SUM(ac.principal_amount) > 0 
        THEN COALESCE(SUM(p.collected_amount), 0) / SUM(ac.principal_amount)
        ELSE 0
    END AS collection_rate_7d
FROM actual_cases AS ac
LEFT JOIN contacts_7d AS ct ON ac.case_id = ct.case_id
LEFT JOIN payments_7d AS p ON ac.case_id = p.case_id
GROUP BY ac.strategy_name;
